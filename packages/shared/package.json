{
  "name": "@ferroui/shared",
  "version": "2.0.1",
  "private": true,
  "description": "Shared utilities, types, and constants for FerroUI.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "default": "./dist/utils.js"
    },
    "./node-crypto": {
      "types": "./dist/node-crypto.d.ts",
      "default": "./dist/node-crypto.js"
    }
  },
  "engines": {
    "node": ">=25"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/**/*.ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "ferroui",
    "shared",
    "utilities"
  ],
  "devDependencies": {
    "@ferroui/config": "workspace:*",
    "@types/node": "^25.8.0",
    "typescript": "latest"
  }
}
