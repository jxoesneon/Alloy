{
  "name": "@ferroui/cli",
  "version": "2.0.1",
  "private": true,
  "description": "The primary interface for FerroUI development, providing CLI commands for project management.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ferroui": "bin/ferroui.js"
  },
  "engines": {
    "node": ">=25"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --experimental-strip-types src/index.ts",
    "test": "vitest run"
  },
  "keywords": [
    "ferroui",
    "cli",
    "development"
  ],
  "dependencies": {
    "@ferroui/registry": "workspace:*",
    "@ferroui/schema": "workspace:*",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.4",
    "globby": "^16.2.0",
    "handlebars": "^4.7.9",
    "ora": "^9.3.0",
    "prompts": "^2.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.6.2",
    "@types/prompts": "^2.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
